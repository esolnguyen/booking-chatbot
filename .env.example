AZURE_OPENAI_API_KEY=your-azure-openai-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project/openai/v1
AZURE_OPENAI_CHAT_DEPLOYMENT=your-chat-deployment-name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your-embedding-deployment-name

# Set to false to skip LLM verification (deterministic checks only, faster)
VERIFICATION_LLM_ENABLED=true

# Set to true to use rule-based intent parsing (instant, no LLM call for common queries)
# Falls back to LLM automatically when rules can't confidently parse the input
INTENT_RULE_BASED=false
